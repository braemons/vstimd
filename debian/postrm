#!/bin/bash
set -e

if [ "$1" = "purge" ]; then
    # Remove the vstimd system user and its primary group on full purge.
    # On plain remove (apt remove) the user is left in place so that
    # locally created config files remain accessible.
    if id -u vstimd > /dev/null 2>&1; then
        deluser --system vstimd || true
    fi
    if getent group vstimd > /dev/null 2>&1; then
        delgroup --system vstimd || true
    fi
fi

#DEBHELPER#
